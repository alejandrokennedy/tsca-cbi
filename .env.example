# AEM push credentials — copy to `.env` and fill in.  `.env` is gitignored.
# Used by `pnpm push:aem` / `pnpm upload:aem` (tasks/push-aem.ts).
#
# AEM_HOST is the AEM *author* origin (no trailing path).
# The target DAM folder comes from aem.config.json's `damBase`.
# The folder must already exist in AEM.

AEM_HOST=https://author-pXXXXX-eYYYYY.adobeaemcloud.com

# Pick ONE auth mode and fill in its vars:
AEM_AUTH=bearer        # bearer | basic | oauth

# --- bearer: AEMaaCS, quick testing -----------------------------------------
# Paste a Local Development Token from the AEM Developer Console
# (Cloud Manager → Environment → Developer Console → Integrations). Expires ~24h.
AEM_TOKEN=

# --- oauth: AEMaaCS, automation ---------------------------------------------
# From an OAuth Server-to-Server (technical account) credential in the AEM
# Developer Console → Integrations. The script mints a short-lived IMS token.
# AEM_CLIENT_ID=
# AEM_CLIENT_SECRET=
# AEM_SCOPES=
# AEM_IMS_HOST=https://ims-na1.adobelogin.com   # override only if not NA1

# --- basic: AEM 6.5 / AMS (on-prem) -----------------------------------------
# An author account with write access to the DAM path.
# AEM_USER=
# AEM_PASSWORD=
