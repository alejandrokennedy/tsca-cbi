{
	"name": "svelte-starter",
	"version": "6.19.0",
	"scripts": {
		"gdoc": "node tasks/fetch-google.js",
		"style": "node tasks/style-dictionary.js",
		"dev": "vite dev",
		"build": "vite build",
		"convert:aem": "tsx tasks/convert-svelte.ts",
		"build:aem": "vite build && tsx tasks/convert-svelte.ts",
		"preview": "vite preview",
		"lint": "prettier --check --plugin-search-dir=. .",
		"format": "prettier --write --plugin-search-dir=. .",
		"sda": "tsx tasks/sda.ts",
